# Single environment file for the whole project.
# Local dev: copy to ./.env in the repository root.
# Production: /opt/agents44/.env (loaded by systemd and the backend).

# Database
PSQL_HOST=localhost
PSQL_PORT=5432
PSQL_DB=agents44
PSQL_USER=agents44
PSQL_PASSWORD=agents44

# Flask
FLASK_SECRET_KEY=change-me-dev-secret
WORKSPACE_PATH=./.workspace
FRONTEND_URL=http://localhost:3000

# Local development (omit or leave unset on production)
FLASK_APP=wsgi:app
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
RUNTIME_DIR=./.dev/runtime
LOG_DIR=./.dev/logs

# Dev login (omit or leave DEV_LOGIN_EMAIL empty to disable)
DEV_LOGIN_EMAIL=admin@catch44.co.il
DEV_LOGIN_PASSWORD=change-me-dev-password

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:5000/api/auth/callback

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=admin@catch44.co.il
SMTP_APP_PASSWORD=
ADMIN_EMAIL=admin@catch44.co.il

# Claude (required for agent runs)
ANTHROPIC_API_KEY=
DEFAULT_MODEL=

# Embedded MCP server (localhost only; Flask API uses port 5000)
MCP_PORT=5001

# Frontend dev server (Vite HMR; proxies /api to Flask — no nginx locally)
REACT_APP_API_URL=/api
